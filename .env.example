DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/cyshield"
PORT=5000
NODE_ENV=development

# Threat intelligence API keys (for IP enrichment in reports and Intelligence)
ABUSEIPDB_API_KEY=your_abuseipdb_key
VIRUSTOTAL_API_KEY=your_virustotal_key

# Optional: AI (Ollama) – local LLM for insights, enrichment, report summaries
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=tinyllama
# OLLAMA_ENABLED=1

# Optional: Tavily – web search for AI insights threat intel (https://tavily.com)
# TAVILY_API_KEY=your_tavily_key

# Optional: NVD (NIST) API key for CVE lookup – 50 req/30s with key vs 5 req/30s without
# Get key at https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=your_nvd_key

# Optional: tune Node/TypeScript behavior
# LOG_LEVEL=info
